---
import BaseLayout from "./BaseLayout.astro";
import Sidebar from "../components/Sidebar.astro";
import TableOfContents from "../components/TableOfContents.astro";
import ChapterNav from "../components/ChapterNav.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import type { ChapterMeta } from "../lib/chapters";

interface Props {
  title: string;
  description: string;
  chapter?: number;
  part?: number;
  partTitle?: string;
  headings: { depth: number; slug: string; text: string }[];
  allChapters: ChapterMeta[];
  currentSlug: string;
}

const { title, description, chapter, part, partTitle, headings, allChapters, currentSlug } = Astro.props;

const pageTitle = chapter
  ? `Ch. ${String(chapter).padStart(2, "0")}: ${title} | The Agentic Engineering Guide`
  : `${title} | The Agentic Engineering Guide`;
---

<BaseLayout title={pageTitle} description={description}>
  <Header />
  <div class="flex min-h-screen pt-14">
    <!-- Sidebar -->
    <Sidebar chapters={allChapters} currentSlug={currentSlug} />

    <!-- Main content -->
    <main class="flex-1 min-w-0 lg:pl-64">
      <div class="max-w-[1100px] mx-auto flex">
        <article class="flex-1 min-w-0 px-6 py-10 lg:px-12 lg:py-14">
          <!-- Chapter header -->
          <header class="mb-10 pb-8 border-b border-[var(--border)]">
            {chapter && (
              <span class="font-[var(--font-mono)] text-xs tracking-widest uppercase text-[var(--text-tertiary)] mb-2 block">
                Ch. {String(chapter).padStart(2, "0")}
              </span>
            )}
            <h1 class="text-3xl lg:text-4xl font-semibold tracking-tight leading-tight mb-3">
              {title}
            </h1>
            {part && partTitle && (
              <span class="text-sm text-[var(--text-tertiary)]">
                Part {part} / {partTitle}
              </span>
            )}
          </header>

          <!-- Content -->
          <div class="prose" data-pagefind-body>
            <slot />
          </div>

          <!-- Prev / Next -->
          <ChapterNav chapters={allChapters} currentSlug={currentSlug} />
        </article>

        <!-- Right rail: Table of Contents -->
        <TableOfContents headings={headings} />
      </div>
    </main>
  </div>
  <Footer />
</BaseLayout>
