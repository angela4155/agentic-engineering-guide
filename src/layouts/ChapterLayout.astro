---
import BaseLayout from "./BaseLayout.astro";
import Sidebar from "../components/Sidebar.astro";
import TableOfContents from "../components/TableOfContents.astro";
import ChapterNav from "../components/ChapterNav.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import type { ChapterMeta } from "../lib/chapters";

interface Props {
  title: string;
  description: string;
  chapter?: number;
  part?: number;
  partTitle?: string;
  headings: { depth: number; slug: string; text: string }[];
  allChapters: ChapterMeta[];
  currentSlug: string;
}

const { title, description, chapter, part, partTitle, headings, allChapters, currentSlug } = Astro.props;

const pageTitle = chapter
  ? `Ch. ${String(chapter).padStart(2, "0")}: ${title} | The Agentic Engineering Guide`
  : `${title} | The Agentic Engineering Guide`;

const editUrl = `https://github.com/Siddhant-K-code/agentic-engineering-guide/edit/main/src/content/chapters/${currentSlug}.mdx`;
---

<BaseLayout title={pageTitle} description={description}>
  <Header />
  <div class="flex min-h-screen pt-12">
    <Sidebar chapters={allChapters} currentSlug={currentSlug} />

    <main class="flex-1 min-w-0 lg:pl-60">
      <div class="max-w-[1080px] mx-auto flex">
        <article class="flex-1 min-w-0 px-6 py-10 lg:px-10 lg:py-12">
          <!-- Chapter header -->
          <header class="mb-8 pb-6 border-b border-[var(--border-subtle)]">
            <div class="flex items-center gap-2 mb-3">
              {chapter && (
                <span class="font-[var(--font-mono)] text-[11px] tracking-[0.15em] uppercase text-[var(--text-tertiary)]">
                  Ch. {String(chapter).padStart(2, "0")}
                </span>
              )}
              {part && partTitle && (
                <>
                  {chapter && <span class="text-[var(--border)]">·</span>}
                  <span class="font-[var(--font-mono)] text-[11px] tracking-wider text-[var(--text-tertiary)]">
                    Part {part} / {partTitle}
                  </span>
                </>
              )}
            </div>
            <h1 class="text-2xl lg:text-[1.75rem] font-semibold tracking-[-0.02em] leading-tight mb-3">
              {title}
            </h1>
            <div class="flex items-center gap-3 text-[12px] text-[var(--text-tertiary)]">
              <a
                href={editUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1 hover:text-[var(--text-secondary)] transition-colors"
              >
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" /><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                </svg>
                Edit on GitHub
              </a>
            </div>
          </header>

          <!-- Content -->
          <div class="prose" data-pagefind-body>
            <slot />
          </div>

          <ChapterNav chapters={allChapters} currentSlug={currentSlug} />
        </article>

        <TableOfContents headings={headings} />
      </div>
    </main>
  </div>
  <Footer />
</BaseLayout>
