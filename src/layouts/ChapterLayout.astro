---
import BaseLayout from "./BaseLayout.astro";
import Sidebar from "../components/Sidebar.astro";
import TableOfContents from "../components/TableOfContents.astro";
import ChapterNav from "../components/ChapterNav.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import type { ChapterMeta } from "../lib/chapters";

interface Props {
  title: string;
  description: string;
  chapter?: number;
  part?: number;
  partTitle?: string;
  headings: { depth: number; slug: string; text: string }[];
  allChapters: ChapterMeta[];
  currentSlug: string;
}

const { title, description, chapter, part, partTitle, headings, allChapters, currentSlug } = Astro.props;

const pageTitle = chapter
  ? `Ch. ${String(chapter).padStart(2, "0")}: ${title} | The Agentic Engineering Guide`
  : `${title} | The Agentic Engineering Guide`;

const editUrl = `https://github.com/Siddhant-K-code/agentic-engineering-guide/edit/main/src/content/chapters/${currentSlug}.mdx`;
const feedbackUrl = `https://github.com/Siddhant-K-code/agentic-engineering-guide/issues/new?title=Feedback:+${encodeURIComponent(title)}&labels=feedback`;
---

<BaseLayout title={pageTitle} description={description}>
  <Header />
  <div class="flex min-h-screen pt-14">
    <!-- Sidebar -->
    <Sidebar chapters={allChapters} currentSlug={currentSlug} />

    <!-- Main content -->
    <main class="flex-1 min-w-0 lg:pl-64">
      <div class="max-w-[1100px] mx-auto flex">
        <article class="flex-1 min-w-0 px-6 py-10 lg:px-12 lg:py-14">
          <!-- Chapter header -->
          <header class="mb-10 pb-8 border-b border-[var(--border)]">
            {chapter && (
              <span class="font-[var(--font-mono)] text-xs tracking-widest uppercase text-[var(--text-tertiary)] mb-2 block">
                Ch. {String(chapter).padStart(2, "0")}
              </span>
            )}
            <h1 class="text-3xl lg:text-4xl font-semibold tracking-tight leading-tight mb-3">
              {title}
            </h1>
            {part && partTitle && (
              <span class="text-sm text-[var(--text-tertiary)]">
                Part {part} / {partTitle}
              </span>
            )}
            <div class="mt-3 flex flex-wrap gap-3">
              <a
                href={editUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1 text-xs text-[var(--text-tertiary)] hover:text-[var(--text-secondary)] transition-colors"
              >
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" /><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                </svg>
                Edit on GitHub
              </a>
              <a
                href={feedbackUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1 text-xs text-[var(--text-tertiary)] hover:text-[var(--text-secondary)] transition-colors"
              >
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                </svg>
                Suggest Feedback
              </a>
            </div>
          </header>

          <!-- Content -->
          <div class="prose" data-pagefind-body>
            <slot />
          </div>

          <!-- Prev / Next -->
          <ChapterNav chapters={allChapters} currentSlug={currentSlug} />
        </article>

        <!-- Right rail: Table of Contents -->
        <TableOfContents headings={headings} editUrl={editUrl} feedbackUrl={feedbackUrl} />
      </div>
    </main>
  </div>
  <Footer />
</BaseLayout>
