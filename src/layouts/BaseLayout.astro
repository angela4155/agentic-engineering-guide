---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Concepts, workflows, and team practices for AI agent infrastructure. 10 Parts · 33 Chapters." } = Astro.props;
const gaId = import.meta.env.PUBLIC_GA_ID || "G-XXXXXXX";
const siteUrl = Astro.site?.toString().replace(/\/$/, "") || "";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#fafafa" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="The Agentic Engineering Guide" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:creator" content="@Siddhant_K_code" />

    <!-- Favicon -->
    <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />

    <!-- Google Analytics -->
    {gaId !== "G-XXXXXXX" && (
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
      <script define:vars={{ gaId }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', gaId);
      </script>
    )}

    <!-- Theme: apply before paint to prevent flash -->
    <script is:inline>
      (function() {
        var stored = localStorage.getItem('theme');
        if (stored === 'dark') {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="bg-[var(--bg-primary)] text-[var(--text-primary)] min-h-screen">
    <slot />
  </body>
</html>
