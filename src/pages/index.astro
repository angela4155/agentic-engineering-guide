---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Sidebar from "../components/Sidebar.astro";
import Footer from "../components/Footer.astro";
import { getCollection } from "astro:content";
import { groupByPart, type ChapterMeta } from "../lib/chapters";

const allEntries = await getCollection("chapters");
const allChapters: ChapterMeta[] = allEntries.map((e) => ({
  slug: e.id,
  title: e.data.title,
  chapter: e.data.chapter,
  part: e.data.part,
  partTitle: e.data.partTitle,
  order: e.data.order,
}));
const groups = groupByPart(allChapters);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const totalChapters = allChapters.filter((c) => c.chapter).length;
---

<BaseLayout title="The Agentic Engineering Guide | AI Agent Infrastructure Book">
  <Header />
  <Sidebar chapters={allChapters} currentSlug="" />

  <main class="pt-14">
    <!-- Hero -->
    <section class="border-b border-[var(--border-subtle)]">
      <div class="max-w-3xl mx-auto px-6 py-20 lg:py-28">
        <span class="font-[var(--font-mono)] text-xs tracking-widest uppercase text-[var(--text-tertiary)] mb-4 block">
          /Book
        </span>
        <h1 class="text-4xl lg:text-5xl font-semibold tracking-tight leading-[1.1] mb-4">
          The Agentic<br />Engineering Guide
        </h1>
        <p class="text-lg text-[var(--text-secondary)] leading-relaxed max-w-xl mb-3">
          Concepts, workflows, and team practices for AI agent infrastructure.
        </p>
        <p class="text-sm text-[var(--text-tertiary)] mb-8">
          10 Parts · {totalChapters} Chapters
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href={`${base}/preface/`}
            class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium bg-[var(--text-primary)] text-[var(--bg-primary)] rounded-md hover:opacity-90 transition-opacity"
          >
            Start Reading →
          </a>
          <a
            href="https://siddhantkhar5.gumroad.com/l/agentic-engineering-guide"
            target="_blank"
            rel="noopener noreferrer"
            class="gumroad-btn inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium rounded-md transition-all"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
              <polyline points="14 2 14 8 20 8" />
              <line x1="16" y1="13" x2="8" y2="13" />
              <line x1="16" y1="17" x2="8" y2="17" />
              <polyline points="10 9 9 9 8 9" />
            </svg>
            Grab the PDF
          </a>
          <a
            href="https://github.com/Siddhant-K-code/agentic-engineering-guide"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium border border-[var(--border)] rounded-md hover:border-[var(--text-tertiary)] transition-colors"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            GitHub
          </a>
        </div>
      </div>
    </section>

    <!-- About -->
    <section class="border-b border-[var(--border-subtle)]">
      <div class="max-w-3xl mx-auto px-6 py-14">
        <span class="font-[var(--font-mono)] text-xs tracking-widest uppercase text-[var(--text-tertiary)] mb-4 block">
          /About
        </span>
        <p class="text-[var(--text-secondary)] leading-relaxed max-w-xl">
          This book is for engineering leaders navigating the shift to AI-assisted development. It covers the decisions, trade-offs, and organizational patterns that determine whether AI agents become a force multiplier or a source of burnout. From context engineering to cost control, from authorization to adoption playbooks.
        </p>
      </div>
    </section>

    <!-- Table of Contents -->
    <section class="border-b border-[var(--border-subtle)]">
      <div class="max-w-3xl mx-auto px-6 py-14">
        <span class="font-[var(--font-mono)] text-xs tracking-widest uppercase text-[var(--text-tertiary)] mb-6 block">
          /Table of Contents
        </span>
        <div class="space-y-8">
          {groups.map((group) => (
            <div>
              {group.part > 0 && group.part < 99 ? (
                <div class="mb-3">
                  <span class="font-[var(--font-mono)] text-xs tracking-wider text-[var(--text-tertiary)]">
                    Part {group.part}
                  </span>
                  <span class="text-sm font-medium text-[var(--text-secondary)] ml-2">
                    / {group.title}
                  </span>
                </div>
              ) : group.part === 99 ? (
                <div class="mb-3 pt-4 border-t border-[var(--border-subtle)]">
                  <span class="font-[var(--font-mono)] text-xs tracking-wider text-[var(--text-tertiary)]">
                    {group.title}
                  </span>
                </div>
              ) : null}
              <ul class="space-y-1">
                {group.chapters.map((ch) => (
                  <li>
                    <a
                      href={`${base}/${ch.slug}/`}
                      class="flex items-start gap-3 py-1 text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors"
                    >
                      {ch.chapter ? (
                        <span class="font-[var(--font-mono)] text-xs text-[var(--text-tertiary)] mt-0.5 w-5 shrink-0">
                          {String(ch.chapter).padStart(2, "0")}
                        </span>
                      ) : (
                        <span class="w-5 shrink-0" />
                      )}
                      <span>{ch.title}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Author -->
    <section>
      <div class="max-w-3xl mx-auto px-6 py-14">
        <span class="font-[var(--font-mono)] text-xs tracking-widest uppercase text-[var(--text-tertiary)] mb-4 block">
          /Author
        </span>
        <div class="flex items-start gap-4">
          <img
            src={`${base}/images/author.webp`}
            alt="Siddhant Khare"
            width="48"
            height="48"
            class="w-12 h-12 rounded-full object-cover shrink-0"
          />
          <div>
            <p class="text-[var(--text-secondary)] leading-relaxed max-w-xl mb-3">
              <strong class="text-[var(--text-primary)]">Siddhant Khare</strong> is a software engineer at <a href="https://ona.com" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 hover:text-[var(--text-primary)] transition-colors">Ona</a> and a maintainer of <a href="https://openfga.dev" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 hover:text-[var(--text-primary)] transition-colors">OpenFGA</a> (CNCF Incubating). His essay <a href="https://siddhantkhare.com/writing/ai-fatigue-is-real" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 hover:text-[var(--text-primary)] transition-colors">"AI fatigue is real and nobody talks about it"</a> reached #1 on Hacker News and was covered by Business Insider, Futurism, NDTV, and others.
            </p>
            <div class="flex gap-4 text-sm text-[var(--text-tertiary)]">
              <a href="https://twitter.com/Siddhant_K_code" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--text-primary)] transition-colors">Twitter</a>
              <a href="https://linkedin.com/in/Siddhant-K-code" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--text-primary)] transition-colors">LinkedIn</a>
              <a href="https://github.com/Siddhant-K-code" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--text-primary)] transition-colors">GitHub</a>
              <a href="https://siddhantkhare.com" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--text-primary)] transition-colors">Website</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
