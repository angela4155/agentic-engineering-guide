---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getCollection } from "astro:content";
import { groupByPart, type ChapterMeta } from "../lib/chapters";

const allEntries = await getCollection("chapters");
const allChapters: ChapterMeta[] = allEntries.map((e) => ({
  slug: e.id,
  title: e.data.title,
  chapter: e.data.chapter,
  part: e.data.part,
  partTitle: e.data.partTitle,
  order: e.data.order,
}));
const groups = groupByPart(allChapters);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const totalChapters = allChapters.filter((c) => c.chapter).length;
---

<BaseLayout title="The Agentic Engineering Guide | Siddhant Khare">
  <Header />

  <main class="pt-14">
    <!-- Hero -->
    <section class="relative overflow-hidden">
      <div class="max-w-2xl mx-auto px-6 pt-16 pb-20 lg:pt-24 lg:pb-28">
        <p class="font-[var(--font-mono)] text-[11px] tracking-[0.2em] uppercase text-[var(--text-tertiary)] mb-6">
          Open-source book
        </p>
        <h1 class="text-[2.5rem] lg:text-[3.25rem] font-semibold tracking-[-0.035em] leading-[1.08] mb-5 text-[var(--text-primary)]">
          The Agentic<br />Engineering Guide
        </h1>
        <p class="text-base text-[var(--text-secondary)] leading-[1.7] max-w-lg mb-8">
          Concepts, workflows, and team practices for AI agent infrastructure. From context engineering to cost control, from authorization to adoption playbooks.
        </p>
        <div class="flex items-center gap-3 text-[13px] text-[var(--text-tertiary)] mb-10 font-[var(--font-mono)]">
          <span>{totalChapters} chapters</span>
          <span class="text-[var(--border)]">·</span>
          <span>10 parts</span>
          <span class="text-[var(--border)]">·</span>
          <span>Siddhant Khare</span>
        </div>
        <div class="flex items-center gap-3">
          <a
            href={`${base}/preface/`}
            class="inline-flex items-center gap-2 h-9 px-4 text-[13px] font-medium bg-[var(--text-primary)] text-[var(--bg-primary)] rounded-md hover:opacity-90 transition-opacity"
          >
            Start reading
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <a
            href="https://github.com/Siddhant-K-code/agentic-engineering-guide"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 h-9 px-4 text-[13px] font-medium border border-[var(--border)] text-[var(--text-secondary)] rounded-md hover:border-[var(--text-tertiary)] hover:text-[var(--text-primary)] transition-colors"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            Source
          </a>
        </div>
      </div>
      <!-- Subtle decorative element -->
      <div class="absolute top-0 right-0 w-[400px] h-[400px] opacity-[0.03] pointer-events-none" aria-hidden="true">
        <svg viewBox="0 0 400 400" fill="none" stroke="var(--text-primary)" stroke-width="0.5">
          <circle cx="200" cy="200" r="60" /><circle cx="200" cy="200" r="120" /><circle cx="200" cy="200" r="180" />
          <line x1="200" y1="20" x2="200" y2="380" /><line x1="20" y1="200" x2="380" y2="200" />
        </svg>
      </div>
    </section>

    <div class="h-px bg-[var(--border-subtle)]" />

    <!-- Table of Contents -->
    <section>
      <div class="max-w-2xl mx-auto px-6 py-16">
        <p class="font-[var(--font-mono)] text-[11px] tracking-[0.2em] uppercase text-[var(--text-tertiary)] mb-8">
          Contents
        </p>
        <div class="space-y-10">
          {groups.map((group) => (
            <div>
              {group.part > 0 && group.part < 99 && (
                <div class="flex items-baseline gap-3 mb-3">
                  <span class="font-[var(--font-mono)] text-[11px] tracking-wider text-[var(--text-tertiary)] tabular-nums">
                    {String(group.part).padStart(2, "0")}
                  </span>
                  <span class="text-[13px] font-medium text-[var(--text-primary)]">
                    {group.title}
                  </span>
                </div>
              )}
              {group.part === 99 && (
                <div class="mb-3 pt-6">
                  <span class="text-[13px] font-medium text-[var(--text-tertiary)]">
                    {group.title}
                  </span>
                </div>
              )}
              <ul class="space-y-0.5">
                {group.chapters.map((ch) => (
                  <li>
                    <a
                      href={`${base}/${ch.slug}/`}
                      class="group flex items-baseline gap-3 py-[5px] text-[14px] text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors"
                    >
                      <span class="font-[var(--font-mono)] text-[11px] text-[var(--text-tertiary)] tabular-nums w-5 shrink-0 group-hover:text-[var(--text-secondary)] transition-colors">
                        {ch.chapter ? String(ch.chapter).padStart(2, "0") : ""}
                      </span>
                      <span class="group-hover:translate-x-0.5 transition-transform duration-150">{ch.title}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div class="h-px bg-[var(--border-subtle)]" />

    <!-- Author -->
    <section>
      <div class="max-w-2xl mx-auto px-6 py-16">
        <p class="font-[var(--font-mono)] text-[11px] tracking-[0.2em] uppercase text-[var(--text-tertiary)] mb-5">
          Author
        </p>
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-full bg-[var(--bg-tertiary)] flex items-center justify-center shrink-0">
            <span class="text-sm font-semibold text-[var(--text-secondary)]">SK</span>
          </div>
          <div>
            <p class="text-[15px] font-medium text-[var(--text-primary)] mb-1">Siddhant Khare</p>
            <p class="text-[13px] text-[var(--text-tertiary)] leading-relaxed mb-3">
              Software Engineer at Ona. OpenFGA Maintainer (CNCF).
            </p>
            <div class="flex gap-4 text-[12px] text-[var(--text-tertiary)]">
              <a href="https://twitter.com/Siddhant_K_code" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--text-primary)] transition-colors">Twitter</a>
              <a href="https://github.com/Siddhant-K-code" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--text-primary)] transition-colors">GitHub</a>
              <a href="https://siddhantkhare.com" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--text-primary)] transition-colors">Website</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
