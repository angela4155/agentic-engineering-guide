---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
  editUrl?: string;
  feedbackUrl?: string;
}

const { headings, editUrl, feedbackUrl } = Astro.props;
const filtered = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filtered.length > 0 && (
  <aside class="hidden xl:block w-52 shrink-0 sticky top-14 h-[calc(100vh-3.5rem)] py-10 pr-6">
    <nav class="overflow-y-auto max-h-full">
      <span class="font-[var(--font-mono)] text-[10px] tracking-widest uppercase text-[var(--text-tertiary)] mb-3 block">
        On this page
      </span>
      <ul class="space-y-1.5">
        {filtered.map((h) => (
          <li>
            <a
              href={`#${h.slug}`}
              class:list={[
                "block text-xs leading-relaxed transition-colors hover:text-[var(--text-primary)]",
                h.depth === 2 ? "text-[var(--text-secondary)]" : "text-[var(--text-tertiary)] pl-3",
              ]}
              data-toc-link
              data-toc-slug={h.slug}
            >
              {h.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    {(editUrl || feedbackUrl) && (
      <div class="mt-6 pt-4 border-t border-[var(--border-subtle)] flex flex-col gap-1.5">
        {editUrl && (
          <a
            href={editUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-[11px] text-[var(--text-tertiary)] hover:text-[var(--text-secondary)] transition-colors"
          >
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" /><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
            </svg>
            Edit on GitHub
          </a>
        )}
        {feedbackUrl && (
          <a
            href={feedbackUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-[11px] text-[var(--text-tertiary)] hover:text-[var(--text-secondary)] transition-colors"
          >
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
            </svg>
            Suggest Feedback
          </a>
        )}
      </div>
    )}
  </aside>
)}

<script>
  const tocLinks = document.querySelectorAll('[data-toc-link]');
  if (tocLinks.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            tocLinks.forEach(link => {
              link.classList.remove('!text-[var(--text-primary)]');
              link.classList.remove('font-medium');
            });
            const active = document.querySelector(`[data-toc-slug="${entry.target.id}"]`);
            if (active) {
              active.classList.add('!text-[var(--text-primary)]');
              active.classList.add('font-medium');
            }
          }
        }
      },
      { rootMargin: '-80px 0px -70% 0px', threshold: 0 }
    );
    document.querySelectorAll('.prose h2[id], .prose h3[id]').forEach(h => observer.observe(h));
  }
</script>
